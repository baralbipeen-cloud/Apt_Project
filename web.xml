<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee 
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
    
    <display-name>Auto Parts E-commerce</display-name>
    
    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin-dashboard</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AdminProductsServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.AdminProductsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminProductsServlet</servlet-name>
        <url-pattern>/admin-products</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AdminUsersServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.AdminUsersServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUsersServlet</servlet-name>
        <url-pattern>/admin-users</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AddProductServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.AddProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddProductServlet</servlet-name>
        <url-pattern>/add-product</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>DeleteProductServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.DeleteProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteProductServlet</servlet-name>
        <url-pattern>/delete-product</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UpdateProductServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.UpdateProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProductServlet</servlet-name>
        <url-pattern>/update-product</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UserHomeServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.UserHomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserHomeServlet</servlet-name>
        <url-pattern>/user-home</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ViewProductsServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.ViewProductsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewProductsServlet</servlet-name>
        <url-pattern>/products</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>SearchProductServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.SearchProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchProductServlet</servlet-name>
        <url-pattern>/search-products</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AddToCartServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.AddToCartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddToCartServlet</servlet-name>
        <url-pattern>/add-to-cart</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ViewCartServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.ViewCartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewCartServlet</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>PlaceOrderServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.PlaceOrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PlaceOrderServlet</servlet-name>
        <url-pattern>/place-order</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>ViewOrdersServlet</servlet-name>
        <servlet-class>com.ecommerce.controller.ViewOrdersServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewOrdersServlet</servlet-name>
        <url-pattern>/my-orders</url-pattern>
    </servlet-mapping>
    
    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/notFound.jsp</location>
    </error-page>
    
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
</web-app>